generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id           Int      @id @default(autoincrement())
  name         String
  slug         String   @unique
  category     String
  imageUrl     String?
  affiliateUrl String
  createdAt    DateTime @default(now())

  mentions     RedditMention[]
}

model RedditMention {
  id        Int    @id @default(autoincrement())
  comment   String
  upvotes   Int
  subreddit String
  redditUrl String

  productId Int
  product   Product @relation(fields: [productId], references: [id])
}